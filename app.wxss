page {
  background: #f3f6fb;
  color: #18212f;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.shell {
  padding: 28rpx 24rpx 196rpx;
}

.hero-card,
.surface-card,
.product-card,
.section-card,
.order-card,
.cart-card {
  box-sizing: border-box;
  border-radius: 32rpx;
}

.hero-card,
.surface-card,
.section-card,
.order-card,
.cart-card {
  background: rgba(255, 255, 255, 0.98);
  border: 1px solid rgba(226, 233, 244, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(31, 54, 88, 0.06);
}

.section-title {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.title-main {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 0.2rpx;
}

.title-sub {
  font-size: 22rpx;
  color: #8a95a6;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f1f5fb;
  border: 1px solid rgba(223, 231, 242, 0.95);
  font-size: 22rpx;
  color: #5f7087;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.price-now {
  font-size: 32rpx;
  font-weight: 700;
  color: #1957d2;
}

.price-old {
  font-size: 22rpx;
  color: #aab4c3;
  text-decoration: line-through;
}

.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1d5fe4, #3f8cff);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(29, 95, 228, 0.2);
}

.ghost-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #f3f6fb;
  border: 1px solid rgba(223, 231, 242, 0.95);
  color: #4f6581;
  font-size: 24rpx;
}
