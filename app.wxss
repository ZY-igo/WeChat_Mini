page {
  background: #f5f7fb;
  color: #18212f;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.shell {
  padding: 24rpx 24rpx 192rpx;
}

.hero-card,
.surface-card,
.product-card,
.section-card,
.order-card,
.cart-card {
  box-sizing: border-box;
  border-radius: 32rpx;
}

.hero-card,
.surface-card,
.section-card,
.order-card,
.cart-card {
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 44rpx rgba(34, 57, 93, 0.08);
}

.section-title {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title-main {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.title-sub {
  font-size: 22rpx;
  color: #7e8898;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  font-size: 22rpx;
  color: #4f6481;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.price-now {
  font-size: 34rpx;
  font-weight: 700;
  color: #1957d2;
}

.price-old {
  font-size: 22rpx;
  color: #aab4c3;
  text-decoration: line-through;
}

.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1957d2, #46a4ff);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 28rpx rgba(25, 87, 210, 0.22);
}

.ghost-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #eef3fb;
  color: #36506f;
  font-size: 24rpx;
}
