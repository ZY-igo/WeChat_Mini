.profile-hero {
  padding: 28rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, #ffffff, #eef5ff);
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.profile-meta {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
}

.profile-id {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8290a3;
}

.profile-stats {
  display: flex;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1px solid rgba(97, 123, 163, 0.12);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8290a3;
}

.quick-card,
.tools-card,
.member-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.order-strip {
  display: flex;
  justify-content: space-between;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 120rpx;
}

.order-count {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: #edf4ff;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.order-label {
  font-size: 22rpx;
  color: #7f8c9d;
}

.tool-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(92, 120, 163, 0.08);
}

.tool-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.tool-title {
  font-size: 28rpx;
  font-weight: 700;
}

.tool-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8894a4;
}

.tool-arrow {
  font-size: 34rpx;
  color: #8d9aab;
}

.member-title {
  font-size: 34rpx;
  font-weight: 700;
}

.member-copy {
  margin: 14rpx 0 22rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7d8999;
}
