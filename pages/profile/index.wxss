.profile-hero {
  padding: 32rpx 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #ff8f1f, #ff6a00);
  color: #ffffff;
  box-shadow: 0 16rpx 38rpx rgba(255, 106, 0, 0.22);
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.28);
  background: rgba(255, 255, 255, 0.16);
}

.profile-meta {
  flex: 1;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.profile-name {
  font-size: 35rpx;
  font-weight: 800;
}

.login-chip {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 20rpx;
  font-weight: 700;
}

.profile-id {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.profile-account {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.profile-stats {
  display: flex;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.16);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.quick-card,
.account-card,
.tools-card,
.member-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.account-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1px solid rgba(255, 229, 212, 0.96);
}

.account-row:last-of-type {
  border-bottom: none;
}

.account-label {
  font-size: 24rpx;
  color: #8d7668;
}

.account-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #2c221c;
}

.logout-btn,
.member-login-btn {
  margin-top: 24rpx;
  width: 100%;
}

.order-strip {
  display: flex;
  justify-content: space-between;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 120rpx;
}

.order-count {
  width: 78rpx;
  height: 78rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff3e4, #ffe5cd);
  color: #d16515;
  line-height: 78rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
}

.order-label {
  font-size: 22rpx;
  color: #8d7668;
}

.settings-head {
  margin-bottom: 18rpx;
}

.settings-group {
  border-radius: 26rpx;
  overflow: hidden;
  background: #fffbf8;
  border: 1px solid rgba(255, 219, 191, 0.92);
}

.tool-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 22rpx;
  border-bottom: 1px solid rgba(255, 229, 212, 0.96);
}

.tool-row:last-child {
  border-bottom: none;
}

.tool-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.tool-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #fff2e3, #ffe2c5);
  line-height: 56rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 800;
  color: #d16515;
}

.tool-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #2c221c;
}

.tool-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9a8577;
}

.tool-arrow {
  font-size: 30rpx;
  color: #d08d54;
}

.member-card {
  background: linear-gradient(180deg, #fff7ef, #ffffff);
}

.member-title {
  font-size: 33rpx;
  font-weight: 800;
  color: #2c221c;
}

.member-copy {
  margin: 14rpx 0 22rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8b7668;
}
