.profile-hero {
  padding: 28rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(160deg, #23150a, #8f5939);
  color: #fff8ef;
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.profile-meta {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
}

.profile-id {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 248, 239, 0.78);
}

.profile-stats {
  display: flex;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1px solid rgba(255, 248, 239, 0.16);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 248, 239, 0.74);
}

.quick-card,
.tools-card,
.member-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.order-strip {
  display: flex;
  justify-content: space-between;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 120rpx;
}

.order-count {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: #f1e2cf;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.order-label {
  font-size: 22rpx;
  color: #806a57;
}

.tool-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(92, 63, 39, 0.08);
}

.tool-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.tool-title {
  font-size: 28rpx;
  font-weight: 700;
}

.tool-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #88715d;
}

.tool-arrow {
  font-size: 34rpx;
  color: #8d7763;
}

.member-title {
  font-size: 34rpx;
  font-weight: 700;
}

.member-copy {
  margin: 14rpx 0 22rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #836e5a;
}
