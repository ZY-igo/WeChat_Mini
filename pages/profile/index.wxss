.profile-hero {
  padding: 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, #ffffff, #f2f7ff);
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
}

.profile-meta {
  flex: 1;
}

.profile-name {
  font-size: 35rpx;
  font-weight: 700;
}

.profile-id {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #93a0b1;
}

.profile-stats {
  display: flex;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1px solid rgba(218, 227, 239, 0.95);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #95a1b2;
}

.quick-card,
.tools-card,
.member-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.order-strip {
  display: flex;
  justify-content: space-between;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 120rpx;
}

.order-count {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: #f3f6fb;
  border: 1px solid rgba(226, 233, 244, 0.92);
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.order-label {
  font-size: 22rpx;
  color: #8e99aa;
}

.settings-head {
  margin-bottom: 18rpx;
}

.settings-group {
  border-radius: 26rpx;
  overflow: hidden;
  background: #fbfcff;
  border: 1px solid rgba(229, 235, 244, 0.92);
}

.tool-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 22rpx;
  border-bottom: 1px solid rgba(231, 236, 244, 0.96);
}

.tool-row:last-child {
  border-bottom: none;
}

.tool-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.tool-badge {
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #f2f6fc, #e9f0fb);
  border: 1px solid rgba(224, 231, 242, 0.92);
  line-height: 52rpx;
  text-align: center;
  font-size: 22rpx;
  color: #607188;
}

.tool-title {
  font-size: 28rpx;
  font-weight: 700;
}

.tool-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #95a0af;
}

.tool-arrow {
  font-size: 30rpx;
  color: #a1acba;
}

.member-title {
  font-size: 33rpx;
  font-weight: 700;
}

.member-copy {
  margin: 14rpx 0 22rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a96a7;
}
