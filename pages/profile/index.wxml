<view class="shell profile-page">
  <view class="hero-card profile-hero">
    <view class="profile-top">
      <image class="avatar" mode="aspectFill" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=400&q=80" />
      <view class="profile-meta">
        <view class="profile-name">MORI 会员</view>
        <view class="profile-id">ID 20260420</view>
      </view>
      <view class="pill">BLACK CARD</view>
    </view>
    <view class="profile-stats">
      <view class="stat-item">
        <view class="stat-value">3,680</view>
        <view class="stat-label">成长值</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">6</view>
        <view class="stat-label">优惠券</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">12</view>
        <view class="stat-label">全部订单</view>
      </view>
    </view>
  </view>

  <view class="surface-card quick-card">
    <view class="section-title">
      <view>
        <view class="title-main">我的订单</view>
        <view class="title-sub">查看配送、签收和售后进度</view>
      </view>
      <view class="pill" bindtap="openOrders">全部订单</view>
    </view>
    <view class="order-strip">
      <block wx:for="{{orderTabs}}" wx:key="label">
        <view class="order-tab" bindtap="openOrders">
          <view class="order-count">{{item.count}}</view>
          <view class="order-label">{{item.label}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="surface-card tools-card">
    <view class="section-title">
      <view>
        <view class="title-main">常用服务</view>
        <view class="title-sub">所有入口都可进入演示页面</view>
      </view>
    </view>
    <block wx:for="{{profileTools}}" wx:key="key">
      <view class="tool-row" data-key="{{item.key}}" bindtap="openService">
        <view>
          <view class="tool-title">{{item.title}}</view>
          <view class="tool-subtitle">{{item.subtitle}}</view>
        </view>
        <view class="tool-arrow">></view>
      </view>
    </block>
  </view>

  <view class="surface-card member-card">
    <view class="member-title">会员权益</view>
    <view class="member-copy">免邮券、专属折扣、新品优先购和生日礼遇都可以在演示页继续查看。</view>
    <view class="action-btn" data-key="member" bindtap="openService">查看权益详情</view>
  </view>
</view>
