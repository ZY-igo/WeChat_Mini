.cart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  margin-bottom: 22rpx;
}

.cart-summary-chip {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #45627f;
  font-size: 22rpx;
}

.cart-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  margin-bottom: 20rpx;
}

.cart-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
}

.cart-body {
  flex: 1;
}

.cart-name {
  font-size: 30rpx;
  font-weight: 700;
}

.cart-subtitle {
  margin: 10rpx 0 14rpx;
  font-size: 22rpx;
  color: #7d8998;
}

.cart-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18rpx;
}

.cart-stepper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.step-btn,
.step-value {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  text-align: center;
  line-height: 56rpx;
}

.step-btn {
  background: #edf3fc;
  font-size: 32rpx;
  color: #335273;
}

.step-value {
  background: #f8fbff;
  font-size: 24rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-desc {
  font-size: 24rpx;
  color: #8390a1;
}

.summary-card {
  padding: 28rpx;
  margin-bottom: 26rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
  font-size: 26rpx;
}

.saved-text {
  color: #ff6b57;
}

.total-row {
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(102, 127, 163, 0.12);
  font-size: 34rpx;
  font-weight: 700;
}

.checkout-btn {
  width: 100%;
  margin-top: 20rpx;
}

.recommend-strip {
  white-space: nowrap;
}

.recommend-card {
  display: inline-flex;
  flex-direction: column;
  width: 230rpx;
  padding: 16rpx;
  margin-right: 18rpx;
}

.recommend-image {
  width: 198rpx;
  height: 198rpx;
  border-radius: 22rpx;
}

.recommend-name {
  margin: 16rpx 0 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.4;
}
