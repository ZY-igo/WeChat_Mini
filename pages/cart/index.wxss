.cart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  margin-bottom: 22rpx;
}

.cart-summary-chip {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #fff0e3;
  color: #d16515;
  font-size: 22rpx;
  font-weight: 700;
}

.cart-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  margin-bottom: 20rpx;
}

.cart-image {
  width: 196rpx;
  height: 196rpx;
  border-radius: 24rpx;
  background: #f6eee8;
}

.cart-body {
  flex: 1;
}

.cart-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #2c221c;
}

.cart-subtitle {
  margin: 10rpx 0 14rpx;
  font-size: 22rpx;
  color: #8c786a;
  line-height: 1.6;
}

.cart-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18rpx;
}

.cart-stepper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.step-btn,
.step-value {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  text-align: center;
  line-height: 56rpx;
}

.step-btn {
  background: #fff1e3;
  color: #d16515;
  font-size: 32rpx;
  font-weight: 700;
}

.step-value {
  background: #fff8f1;
  color: #7a6152;
  font-size: 24rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 16rpx;
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, #fff7ef, #ffffff);
}

.empty-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2c221c;
}

.empty-desc {
  font-size: 24rpx;
  line-height: 1.6;
  color: #8d796c;
}

.summary-card {
  padding: 28rpx;
  margin-bottom: 26rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
  font-size: 26rpx;
  color: #7f6a5c;
}

.saved-text {
  color: #ff5a1f;
}

.total-row {
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(255, 214, 180, 0.9);
  font-size: 34rpx;
  font-weight: 800;
  color: #2c221c;
}

.checkout-btn {
  width: 100%;
  margin-top: 20rpx;
}

.recommend-strip {
  white-space: nowrap;
}

.recommend-card {
  display: inline-flex;
  flex-direction: column;
  width: 230rpx;
  padding: 16rpx;
  margin-right: 18rpx;
}

.recommend-image {
  width: 198rpx;
  height: 198rpx;
  border-radius: 22rpx;
  background: #f6eee8;
}

.recommend-name {
  margin: 16rpx 0 10rpx;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.4;
  color: #2c221c;
}
