<view class="home-page">
  <view class="home-header">
    <view class="header-top">
      <view class="brand-block">
        <view class="brand-name">MORI</view>
        <view class="brand-copy">精选生活百货</view>
      </view>
      <view class="header-action pressable" bindtap="refreshLocation" hover-class="pressable-hover">{{locationLabel}}</view>
    </view>

    <view class="search-bar pressable" bindtap="openSearch" hover-class="pressable-hover">
      <view class="search-icon">搜</view>
      <view class="search-placeholder">搜索商品 / 品牌 / 优惠活动</view>
    </view>

    <scroll-view class="keyword-strip" scroll-x enable-flex>
      <block wx:for="{{topKeywords}}" wx:key="*this">
        <view class="keyword-pill pressable" data-keyword="{{item}}" bindtap="chooseKeyword" hover-class="pressable-hover">{{item}}</view>
      </block>
    </scroll-view>

    <view class="notice-bar">{{notice}}</view>
  </view>

  <view class="shell home-shell">
    <swiper class="hero-swiper" autoplay circular interval="3200">
      <block wx:for="{{heroBanners}}" wx:key="id">
        <swiper-item>
          <view class="hero-banner" style="background-image:url({{item.image}})">
            <view class="hero-mask">
              <view class="hero-badge">{{item.badge}}</view>
              <view class="hero-title">{{item.title}}</view>
              <view class="hero-caption">{{item.caption}}</view>
            </view>
          </view>
        </swiper-item>
      </block>
    </swiper>

    <view class="quick-panel">
      <block wx:for="{{quickEntries}}" wx:key="id">
        <view class="quick-item pressable" data-value="{{item.value}}" bindtap="openService" hover-class="pressable-hover">
          <view class="quick-icon">{{item.icon}}</view>
          <view class="quick-title">{{item.title}}</view>
          <view class="quick-subtitle">{{item.subtitle}}</view>
        </view>
      </block>
    </view>

    <view class="promo-grid">
      <block wx:for="{{promoCards}}" wx:key="id">
        <view class="promo-card">
          <view class="promo-accent">{{item.accent}}</view>
          <view class="promo-title">{{item.title}}</view>
          <view class="promo-desc">{{item.desc}}</view>
        </view>
      </block>
    </view>

    <view class="section-block">
      <view class="section-head">
        <view>
          <view class="section-title">限时秒杀</view>
          <view class="section-subtitle">高频促销位，适合承接首页强转化流量</view>
        </view>
        <view class="section-link">20:00 开抢</view>
      </view>
      <scroll-view class="flash-strip" scroll-x enable-flex>
        <block wx:for="{{flashSale}}" wx:key="id">
          <view class="flash-card pressable" data-id="{{item.id}}" bindtap="openProduct" hover-class="card-press-hover">
            <image class="flash-image" mode="aspectFill" src="{{item.image}}" />
            <view class="flash-tag">{{item.tag}}</view>
            <view class="flash-name">{{item.name}}</view>
            <view class="flash-price-row">
              <text class="flash-price">¥{{item.price}}</text>
              <text class="flash-old-price">¥{{item.originalPrice}}</text>
            </view>
            <view class="flash-progress-track">
              <view class="flash-progress-fill" style="width: {{item.progress}}%"></view>
            </view>
            <view class="flash-progress-text">已抢 {{item.progress}}%</view>
          </view>
        </block>
      </scroll-view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <view>
          <view class="section-title">频道会场</view>
          <view class="section-subtitle">用宫格承接分类入口，减少首页信息拥挤</view>
        </view>
      </view>
      <view class="channel-grid">
        <block wx:for="{{channels}}" wx:key="id">
          <view class="channel-card pressable" data-id="{{item.id}}" bindtap="openCategory" hover-class="card-press-hover">
            <image class="channel-image" mode="aspectFill" src="{{item.image}}" />
            <view class="channel-mask">
              <view class="channel-title">{{item.title}}</view>
              <view class="channel-desc">{{item.desc}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="section-block goods-block">
      <view class="section-head">
        <view>
          <view class="section-title">猜你喜欢</view>
          <view class="section-subtitle">双列商品流适合稳定承接逛逛型浏览</view>
        </view>
      </view>
      <view class="goods-grid">
        <block wx:for="{{featured}}" wx:key="id">
          <view class="goods-card pressable" hover-class="card-press-hover">
            <image class="goods-image" mode="aspectFill" src="{{item.image}}" data-id="{{item.id}}" bindtap="openProduct" />
            <view class="goods-body" data-id="{{item.id}}" bindtap="openProduct">
              <view class="goods-tag">{{item.tag}}</view>
              <view class="goods-name">{{item.name}}</view>
              <view class="goods-subtitle">{{item.subtitle}}</view>
              <view class="goods-meta">销量 {{item.sales}} · 评分 {{item.rating}}</view>
              <view class="goods-price-row">
                <text class="goods-price">¥{{item.price}}</text>
                <text class="goods-old-price">¥{{item.originalPrice}}</text>
              </view>
            </view>
            <view class="goods-footer">
              <view class="goods-cart pressable" data-id="{{item.id}}" bindtap="addToCart" hover-class="action-btn-hover" hover-stop-propagation>加入购物车</view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
