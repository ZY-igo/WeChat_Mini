<view class="shell home-page">
  <view class="hero-card hero">
    <view class="hero-top">
      <view>
        <view class="hero-brand">MORI SHOP</view>
        <view class="hero-title">让日常购物更简单，也更好看。</view>
      </view>
      <view class="pill" data-value="new" bindtap="openService">春季企划</view>
    </view>

    <swiper class="hero-swiper" autoplay circular interval="3200">
      <block wx:for="{{heroBanners}}" wx:key="id">
        <swiper-item>
          <view class="banner" style="background-image:url({{item.image}})">
            <view class="banner-mask">
              <view class="pill hero-badge">{{item.badge}}</view>
              <view class="banner-title">{{item.title}}</view>
              <view class="banner-caption">{{item.caption}}</view>
            </view>
          </view>
        </swiper-item>
      </block>
    </swiper>

    <view class="quick-grid">
      <block wx:for="{{quickEntries}}" wx:key="id">
        <view class="quick-entry" data-value="{{item.value}}" bindtap="openService">
          <view class="quick-title">{{item.title}}</view>
          <view class="quick-subtitle">{{item.subtitle}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="section-title">
    <view>
      <view class="title-main">分类精选</view>
      <view class="title-sub">从穿搭、家居到食品，一次逛全</view>
    </view>
    <view class="pill" bindtap="goCategory">查看全部</view>
  </view>
  <scroll-view class="category-strip" scroll-x enable-flex>
    <block wx:for="{{catalog}}" wx:key="id">
      <view class="surface-card category-tile" data-id="{{item.id}}" bindtap="openCategory">
        <image class="category-image" mode="aspectFill" src="{{item.cover}}" />
        <view class="category-name">{{item.name}}</view>
        <view class="category-desc">{{item.description}}</view>
      </view>
    </block>
  </scroll-view>

  <view class="surface-card flash-card">
    <view class="section-title">
      <view>
        <view class="title-main">限时精选</view>
        <view class="title-sub">精选单品今日价更低</view>
      </view>
      <view class="pill">20:00 截止</view>
    </view>
    <view class="flash-list">
      <block wx:for="{{flashSale}}" wx:key="id">
        <view class="flash-item" data-id="{{item.id}}" bindtap="openProduct">
          <image class="flash-image" mode="aspectFill" src="{{item.image}}" />
          <view class="flash-info">
            <view class="flash-name">{{item.name}}</view>
            <view class="price-now">¥{{item.price}}</view>
            <view class="progress-track">
              <view class="progress-fill" style="width: {{item.progress}}%"></view>
            </view>
            <view class="flash-foot">已售 {{item.progress}}%</view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="section-title">
    <view>
      <view class="title-main">推荐商品</view>
      <view class="title-sub">适合首页展示，也方便后续接接口</view>
    </view>
  </view>
  <view class="product-grid">
    <block wx:for="{{featured}}" wx:key="id">
      <view class="product-card product-item">
        <image class="product-image" mode="aspectFill" src="{{item.image}}" data-id="{{item.id}}" bindtap="openProduct" />
        <view class="product-body" data-id="{{item.id}}" bindtap="openProduct">
          <view class="product-topline">
            <view class="product-tag">{{item.tag}}</view>
            <view class="product-score">★ {{item.rating}}</view>
          </view>
          <view class="product-name">{{item.name}}</view>
          <view class="product-subtitle">{{item.subtitle}}</view>
          <view class="price-row">
            <text class="price-now">¥{{item.price}}</text>
            <text class="price-old">¥{{item.originalPrice}}</text>
          </view>
        </view>
        <view class="product-actions">
          <view class="pill">销量 {{item.sales}}</view>
          <view class="action-btn" data-id="{{item.id}}" bindtap="addToCart">加入购物车</view>
        </view>
      </view>
    </block>
  </view>
</view>
