.hero {
  padding: 28rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(180deg, #ffffff, #eef6ff);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.hero-brand {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: #7e8ea3;
}

.hero-title {
  width: 460rpx;
  margin-top: 14rpx;
  font-size: 54rpx;
  line-height: 1.14;
  font-weight: 700;
}

.hero-swiper {
  height: 360rpx;
}

.banner {
  height: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  background-size: cover;
  background-position: center;
}

.banner-mask {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  height: 100%;
  padding: 26rpx;
  background: linear-gradient(180deg, rgba(19, 34, 56, 0.08), rgba(19, 34, 56, 0.5));
  color: #ffffff;
}

.hero-badge {
  align-self: flex-start;
  margin-bottom: 14rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
}

.banner-caption {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.quick-entry {
  padding: 22rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
}

.quick-title {
  font-size: 26rpx;
  font-weight: 700;
}

.quick-subtitle {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #8190a2;
}

.category-strip {
  white-space: nowrap;
  margin-bottom: 28rpx;
}

.category-tile {
  display: inline-flex;
  flex-direction: column;
  width: 260rpx;
  padding: 16rpx;
  margin-right: 20rpx;
}

.category-image {
  width: 228rpx;
  height: 208rpx;
  border-radius: 24rpx;
}

.category-name {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.category-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7f8c9c;
}

.flash-card {
  padding: 28rpx;
  margin-bottom: 28rpx;
}

.flash-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.flash-item {
  display: flex;
  gap: 18rpx;
  padding: 8rpx 0;
}

.flash-image {
  width: 200rpx;
  height: 180rpx;
  border-radius: 24rpx;
}

.flash-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.flash-name {
  font-size: 30rpx;
  font-weight: 700;
}

.progress-track {
  width: 100%;
  height: 12rpx;
  margin: 18rpx 0 10rpx;
  border-radius: 999rpx;
  background: #e7eef9;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #1957d2, #46a4ff);
}

.flash-foot {
  font-size: 22rpx;
  color: #7e8a9b;
}

.product-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.product-item {
  overflow: hidden;
  background: #ffffff;
}

.product-image {
  width: 100%;
  height: 360rpx;
}

.product-body {
  padding: 24rpx 24rpx 12rpx;
}

.product-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-tag {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #3162bd;
  font-size: 20rpx;
}

.product-score {
  font-size: 22rpx;
  color: #8491a2;
}

.product-name {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.product-subtitle {
  margin: 10rpx 0 18rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7f8b9b;
}

.product-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx 24rpx;
}
