.hero {
  padding: 30rpx;
  margin-bottom: 30rpx;
  background: linear-gradient(180deg, #ffffff, #f2f7ff);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.hero-brand {
  font-size: 20rpx;
  letter-spacing: 7rpx;
  color: #90a0b3;
}

.hero-title {
  width: 460rpx;
  margin-top: 12rpx;
  font-size: 50rpx;
  line-height: 1.18;
  font-weight: 700;
}

.hero-swiper {
  height: 360rpx;
}

.banner {
  height: 100%;
  border-radius: 30rpx;
  overflow: hidden;
  background-size: cover;
  background-position: center;
}

.banner-mask {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  height: 100%;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(19, 34, 56, 0.06), rgba(19, 34, 56, 0.48));
  color: #ffffff;
}

.hero-badge {
  align-self: flex-start;
  margin-bottom: 14rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.banner-title {
  font-size: 38rpx;
  font-weight: 700;
}

.banner-caption {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
  opacity: 0.94;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.quick-entry {
  padding: 22rpx 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(227, 234, 244, 0.92);
}

.quick-title {
  font-size: 25rpx;
  font-weight: 700;
}

.quick-subtitle {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #91a0b3;
}

.category-strip {
  white-space: nowrap;
  margin-bottom: 28rpx;
}

.category-tile {
  display: inline-flex;
  flex-direction: column;
  width: 260rpx;
  padding: 16rpx;
  margin-right: 20rpx;
}

.category-image {
  width: 228rpx;
  height: 208rpx;
  border-radius: 26rpx;
}

.category-name {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.category-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8d99aa;
}

.flash-card {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.flash-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.flash-item {
  display: flex;
  gap: 18rpx;
  padding: 10rpx 0;
}

.flash-image {
  width: 200rpx;
  height: 180rpx;
  border-radius: 26rpx;
}

.flash-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.flash-name {
  font-size: 29rpx;
  font-weight: 700;
}

.progress-track {
  width: 100%;
  height: 12rpx;
  margin: 18rpx 0 10rpx;
  border-radius: 999rpx;
  background: #e7eef9;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #1957d2, #46a4ff);
}

.flash-foot {
  font-size: 22rpx;
  color: #8f99a8;
}

.product-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.product-item {
  overflow: hidden;
  background: #ffffff;
}

.product-image {
  width: 100%;
  height: 360rpx;
}

.product-body {
  padding: 26rpx 24rpx 14rpx;
}

.product-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-tag {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #f1f5fb;
  color: #4f6480;
  font-size: 20rpx;
}

.product-score {
  font-size: 22rpx;
  color: #98a4b3;
}

.product-name {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.product-subtitle {
  margin: 10rpx 0 18rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8996a7;
}

.product-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx 26rpx;
}
