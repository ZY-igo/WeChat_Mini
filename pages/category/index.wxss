.catalog-shell {
  display: flex;
  gap: 16rpx;
  min-height: 1000rpx;
}

.catalog-sidebar {
  width: 164rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.side-item {
  min-height: 164rpx;
  padding: 24rpx 16rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: rgba(255, 247, 240, 0.94);
  color: #9f7b63;
  border: 1px solid rgba(255, 221, 196, 0.9);
}

.side-item.is-active {
  background: linear-gradient(180deg, #ff9d37, #ff7900);
  color: #ffffff;
  box-shadow: 0 14rpx 26rpx rgba(255, 121, 0, 0.24);
}

.side-item-title {
  font-size: 28rpx;
  font-weight: 800;
}

.side-item-sub {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.45;
  opacity: 0.92;
}

.catalog-main {
  flex: 1;
  height: 1040rpx;
}

.category-header {
  position: relative;
  height: 320rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
  border-radius: 30rpx;
}

.category-cover {
  width: 100%;
  height: 100%;
}

.category-cover-mask {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 26rpx;
  background: linear-gradient(180deg, rgba(64, 28, 2, 0.06), rgba(64, 28, 2, 0.58));
  color: #ffffff;
}

.category-cover-name {
  font-size: 40rpx;
  font-weight: 800;
}

.category-cover-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.category-product {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.category-product-media {
  width: 238rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
}

.category-product-image {
  width: 100%;
  height: 208rpx;
  border-radius: 28rpx;
  background: #f5eee8;
}

.category-price-block {
  display: flex;
  align-items: flex-end;
  min-height: 78rpx;
  padding: 16rpx 8rpx 0;
  box-sizing: border-box;
}

.category-product-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.category-product-top {
  display: flex;
  align-items: center;
}

.category-product-content {
  flex: 1;
}

.category-tag {
  height: 40rpx;
  padding: 0 16rpx;
  font-size: 20rpx;
}

.category-product-name {
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
  color: #2c221c;
}

.category-product-subtitle {
  margin: 12rpx 0 16rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: #8c7668;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.category-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  font-size: 20rpx;
  color: #bc7a40;
}

.category-product-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.small-btn {
  height: 64rpx;
  min-width: 132rpx;
  padding: 0 28rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}
