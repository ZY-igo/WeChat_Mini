.catalog-shell {
  display: flex;
  gap: 20rpx;
  min-height: 1000rpx;
}

.catalog-sidebar {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.side-item {
  padding: 24rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 247, 240, 0.94);
  color: #9f7b63;
  border: 1px solid rgba(255, 221, 196, 0.9);
}

.side-item.is-active {
  background: linear-gradient(180deg, #ff9d37, #ff7900);
  color: #ffffff;
  box-shadow: 0 14rpx 26rpx rgba(255, 121, 0, 0.24);
}

.side-item-title {
  font-size: 28rpx;
  font-weight: 800;
}

.side-item-sub {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.45;
  opacity: 0.92;
}

.catalog-main {
  flex: 1;
  height: 1040rpx;
}

.category-header {
  position: relative;
  height: 320rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
  border-radius: 30rpx;
}

.category-cover {
  width: 100%;
  height: 100%;
}

.category-cover-mask {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 26rpx;
  background: linear-gradient(180deg, rgba(64, 28, 2, 0.06), rgba(64, 28, 2, 0.58));
  color: #ffffff;
}

.category-cover-name {
  font-size: 40rpx;
  font-weight: 800;
}

.category-cover-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.category-product {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx;
  margin-bottom: 20rpx;
}

.category-product-image {
  width: 196rpx;
  height: 196rpx;
  border-radius: 24rpx;
  background: #f5eee8;
}

.category-product-body {
  flex: 1;
}

.category-product-name {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #2c221c;
}

.category-product-subtitle {
  margin: 10rpx 0 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8c7668;
}

.category-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 16rpx;
  font-size: 20rpx;
  color: #bc7a40;
}

.small-btn {
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 22rpx;
}
