.catalog-shell {
  display: flex;
  gap: 20rpx;
  min-height: 1000rpx;
}

.catalog-sidebar {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.side-item {
  padding: 22rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #718094;
}

.side-item.is-active {
  background: linear-gradient(180deg, #eff6ff, #dcecff);
  color: #1d3f6f;
  box-shadow: 0 14rpx 26rpx rgba(43, 92, 188, 0.12);
}

.side-item-title {
  font-size: 28rpx;
  font-weight: 700;
}

.side-item-sub {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.45;
}

.catalog-main {
  flex: 1;
  height: 1040rpx;
}

.category-header {
  position: relative;
  height: 280rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
}

.category-cover {
  width: 100%;
  height: 100%;
}

.category-cover-mask {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(24, 41, 69, 0.12), rgba(24, 41, 69, 0.52));
  color: #ffffff;
}

.category-cover-name {
  font-size: 38rpx;
  font-weight: 700;
}

.category-cover-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.category-product {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx;
  margin-bottom: 20rpx;
}

.category-product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 22rpx;
}

.category-product-body {
  flex: 1;
}

.category-product-name {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.category-product-subtitle {
  margin: 10rpx 0 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7d8999;
}

.category-metrics {
  display: flex;
  gap: 14rpx;
  margin-bottom: 16rpx;
  font-size: 20rpx;
  color: #909cad;
}

.small-btn {
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 22rpx;
}
