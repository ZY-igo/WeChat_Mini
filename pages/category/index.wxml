<view class="shell category-page">
  <view class="section-title">
    <view>
      <view class="title-main">分类选品</view>
      <view class="title-sub">按生活场景浏览，信息会更清晰一些。</view>
    </view>
  </view>

  <view class="catalog-shell">
    <view class="catalog-sidebar">
      <block wx:for="{{categories}}" wx:key="id">
        <view class="side-item pressable {{activeIndex === index ? 'is-active' : ''}}" data-index="{{index}}" bindtap="selectCategory" hover-class="pressable-hover">
          <view class="side-item-title">{{item.name}}</view>
          <view class="side-item-sub">{{item.description}}</view>
        </view>
      </block>
    </view>

    <scroll-view class="catalog-main" scroll-y>
      <view wx:if="{{categories.length}}" class="surface-card category-header">
        <image class="category-cover" mode="aspectFill" src="{{categories[activeIndex].cover}}" />
        <view class="category-cover-mask">
          <view class="category-cover-name">{{categories[activeIndex].name}}</view>
          <view class="category-cover-desc">{{categories[activeIndex].description}}</view>
        </view>
      </view>

      <block wx:if="{{categories.length}}">
        <block wx:for="{{categories[activeIndex].products}}" wx:key="id">
          <view class="surface-card category-product pressable" hover-class="card-press-hover">
            <view class="category-product-media" data-id="{{item.id}}" bindtap="openProduct">
              <image class="category-product-image" mode="aspectFill" src="{{item.image}}" />
              <view class="category-price-block">
                <view class="price-row">
                  <text class="price-now">¥{{item.price}}</text>
                  <text class="price-old">¥{{item.originalPrice}}</text>
                </view>
              </view>
            </view>
            <view class="category-product-body">
              <view class="category-product-top">
                <view class="pill category-tag">{{item.tag}}</view>
              </view>
              <view class="category-product-content" data-id="{{item.id}}" bindtap="openProduct">
                <view class="category-product-name">{{item.name}}</view>
                <view class="category-product-subtitle">{{item.subtitle}}</view>
                <view class="category-metrics">
                  <text>评分 {{item.rating}}</text>
                  <text>库存 {{item.stock}}</text>
                  <text>销量 {{item.sales}}</text>
                </view>
              </view>
              <view class="category-product-footer">
                <view class="action-btn small-btn pressable" data-id="{{item.id}}" bindtap="addToCart" hover-class="action-btn-hover" hover-stop-propagation>加入</view>
              </view>
            </view>
          </view>
        </block>
      </block>
    </scroll-view>
  </view>
</view>
