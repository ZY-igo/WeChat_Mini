.service-head,
.service-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.service-head {
  background: linear-gradient(135deg, #ff9c33, #ff6a00);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(255, 106, 0, 0.18);
}

.service-head .title-main,
.service-head .service-desc {
  color: #ffffff;
}

.service-desc,
.service-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
}

.service-card {
  background: linear-gradient(180deg, #fffaf6, #ffffff);
}

.service-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #2c221c;
}

.field-input {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #fff9f4;
  border: 1px solid rgba(255, 219, 191, 0.92);
  font-size: 26rpx;
  color: #2c221c;
}

.search-form {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.compact-search-btn {
  width: 180rpx;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.tag-pill,
.tag-button {
  width: auto;
}

.tag-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff0e3;
  color: #d16515;
  font-size: 22rpx;
  font-weight: 700;
}

.search-result-card {
  display: flex;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(255, 229, 212, 0.96);
}

.search-result-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.search-result-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
  background: #f6eee8;
}

.search-result-body {
  flex: 1;
}

.search-result-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #2c221c;
}

.search-result-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.coupon-meta {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9a8577;
}
