.order-item {
  padding: 26rpx;
  margin-bottom: 22rpx;
}

.order-head,
.order-foot,
.order-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-head {
  margin-bottom: 18rpx;
}

.order-id {
  font-size: 26rpx;
  font-weight: 700;
}

.order-line {
  padding: 14rpx 0;
  font-size: 24rpx;
  color: #765f4a;
  border-bottom: 1px solid rgba(92, 63, 39, 0.08);
}

.order-foot {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #8d7865;
}

.order-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #23150a;
}
