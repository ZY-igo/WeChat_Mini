.order-tab-strip {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.order-filter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 22rpx;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: #fff1e4;
  color: #d16515;
  font-size: 22rpx;
  font-weight: 700;
}

.order-item {
  padding: 26rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(180deg, #fffaf6, #ffffff);
}

.order-head,
.order-foot,
.order-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-head {
  margin-bottom: 18rpx;
}

.order-id {
  font-size: 26rpx;
  font-weight: 800;
  color: #2c221c;
}

.order-line {
  padding: 14rpx 0;
  font-size: 24rpx;
  color: #7c685b;
  border-bottom: 1px solid rgba(255, 229, 212, 0.9);
}

.order-foot {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #a08a7d;
}

.order-amount {
  font-size: 30rpx;
  font-weight: 800;
  color: #ff5a1f;
}
