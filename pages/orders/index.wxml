<view class="shell orders-page">
  <view class="section-title">
    <view>
      <view class="title-main">订单列表</view>
      <view class="title-sub">当前为前端 Mock 数据，结构可直接替换为真实接口返回。</view>
    </view>
  </view>

  <scroll-view class="order-tab-strip" scroll-x enable-flex>
    <block wx:for="{{orderTabs}}" wx:key="label">
      <view class="order-filter pressable" hover-class="pressable-hover">{{item.label}} {{item.count}}</view>
    </block>
  </scroll-view>

  <block wx:for="{{orderList}}" wx:key="id">
    <view class="order-card order-item pressable" hover-class="card-press-hover">
      <view class="order-head">
        <view class="order-id">{{item.id}}</view>
        <view class="pill">{{item.status}}</view>
      </view>
      <block wx:for="{{item.items}}" wx:key="name" wx:for-item="goods">
        <view class="order-line">
          <text>{{goods.name}}</text>
          <text>x{{goods.quantity}}</text>
          <text>¥{{goods.price}}</text>
        </view>
      </block>
      <view class="order-foot">
        <text>{{item.time}}</text>
        <text class="order-amount">合计 ¥{{item.amount}}</text>
      </view>
    </view>
  </block>
</view>
