.product-page {
  min-height: 100vh;
  padding-bottom: 180rpx;
  background: linear-gradient(180deg, #fff0e3 0, #fff7ef 520rpx, #f8f3ee 521rpx, #f8f3ee 100%);
}

.detail-swiper {
  height: 820rpx;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-shell {
  margin-top: -70rpx;
  position: relative;
  z-index: 2;
}

.detail-summary,
.detail-section {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.detail-summary {
  background: linear-gradient(180deg, #fffaf6, #ffffff);
}

.detail-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-score {
  font-size: 24rpx;
  color: #d16515;
  font-weight: 700;
}

.detail-name {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: #2c221c;
}

.detail-subtitle {
  margin: 12rpx 0 20rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8c776a;
}

.detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #c47f44;
}

.small-title {
  font-size: 30rpx;
}

.feature-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin: 18rpx 0;
}

.feature-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #fff2e3;
  font-size: 22rpx;
  color: #d16515;
  font-weight: 700;
}

.detail-copy,
.service-line {
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a7668;
}

.support-btn {
  margin-top: 18rpx;
}

.detail-recommend-strip {
  white-space: nowrap;
  margin-top: 18rpx;
}

.detail-recommend-card {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  margin-right: 18rpx;
}

.detail-recommend-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 22rpx;
  background: #f6eee8;
}

.detail-recommend-name {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
  color: #2c221c;
}

.detail-recommend-price {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #ff5a1f;
}

.detail-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 18rpx;
  padding: 20rpx 24rpx 36rpx;
  background: rgba(255, 250, 246, 0.96);
  box-shadow: 0 -10rpx 30rpx rgba(168, 84, 18, 0.1);
}

.detail-btn {
  flex: 1;
}
