.product-page {
  min-height: 100vh;
  padding-bottom: 180rpx;
  background: #f5f7fb;
}

.detail-swiper {
  height: 780rpx;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-shell {
  margin-top: -50rpx;
  position: relative;
  z-index: 2;
}

.detail-summary,
.detail-section {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.detail-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-score {
  font-size: 24rpx;
  color: #7f8b9c;
}

.detail-name {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.detail-subtitle {
  margin: 12rpx 0 20rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f8a9b;
}

.detail-meta {
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #8f9aac;
}

.small-title {
  font-size: 30rpx;
}

.feature-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin: 18rpx 0;
}

.feature-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  font-size: 22rpx;
  color: #44607f;
}

.detail-copy,
.service-line {
  font-size: 24rpx;
  line-height: 1.7;
  color: #7d8899;
}

.support-btn {
  margin-top: 18rpx;
}

.detail-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 18rpx;
  padding: 20rpx 24rpx 36rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 30rpx rgba(46, 74, 124, 0.08);
}

.detail-btn {
  flex: 1;
}
