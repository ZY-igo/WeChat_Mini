<view wx:if="{{product}}" class="product-page">
  <swiper class="detail-swiper" autoplay circular>
    <block wx:for="{{product.detailImages}}" wx:key="*this">
      <swiper-item>
        <image class="detail-image" mode="aspectFill" src="{{item}}" />
      </swiper-item>
    </block>
  </swiper>

  <view class="shell detail-shell">
    <view class="surface-card detail-summary">
      <view class="detail-top">
        <view class="pill">{{product.tag}}</view>
        <view class="detail-score">★ {{product.rating}}</view>
      </view>
      <view class="detail-name">{{product.name}}</view>
      <view class="detail-subtitle">{{product.subtitle}}</view>
      <view class="price-row">
        <text class="price-now">¥{{product.price}}</text>
        <text class="price-old">¥{{product.originalPrice}}</text>
      </view>
      <view class="detail-meta">
        <text>销量 {{product.sales}}</text>
        <text>库存 {{product.stock}}</text>
        <text>包邮</text>
      </view>
    </view>

    <view class="surface-card detail-section">
      <view class="title-main small-title">商品亮点</view>
      <view class="feature-list">
        <block wx:for="{{product.features}}" wx:key="*this">
          <view class="feature-pill">{{item}}</view>
        </block>
      </view>
      <view class="detail-copy">当前详情页使用 Mock 数据，但字段结构已经按真实电商详情模型拆分，后续可以继续补图文详情、SKU、评价和推荐流接口。</view>
    </view>

    <view class="surface-card detail-section">
      <view class="title-main small-title">配送与服务</view>
      <view class="service-line">预计 48 小时内发货，支持售后与在线客服。服务类能力已单独预留页面接口。</view>
      <view class="ghost-btn support-btn pressable" bindtap="openService" hover-class="ghost-btn-hover">联系客服</view>
    </view>

    <view class="surface-card detail-section">
      <view class="title-main small-title">你可能还会喜欢</view>
      <scroll-view class="detail-recommend-strip" scroll-x enable-flex>
        <block wx:for="{{recommendList}}" wx:key="id">
          <view class="detail-recommend-card pressable" data-id="{{item.id}}" bindtap="openProduct" hover-class="card-press-hover">
            <image class="detail-recommend-image" mode="aspectFill" src="{{item.image}}" />
            <view class="detail-recommend-name">{{item.name}}</view>
            <view class="detail-recommend-price">¥{{item.price}}</view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>

  <view class="detail-actions">
    <view class="ghost-btn detail-btn pressable" bindtap="addToCart" hover-class="ghost-btn-hover">加入购物车</view>
    <view class="action-btn detail-btn pressable" bindtap="buyNow" hover-class="action-btn-hover">立即购买</view>
  </view>
</view>
