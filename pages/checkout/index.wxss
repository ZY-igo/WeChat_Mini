.checkout-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.checkout-card:first-child {
  background: linear-gradient(135deg, #ff9830, #ff6a00);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(255, 106, 0, 0.18);
}

.checkout-card:first-child .title-main,
.checkout-card:first-child .title-sub {
  color: #ffffff;
}

.checkout-card:first-child .title-sub {
  opacity: 0.82;
}

.checkout-title {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
  color: #2c221c;
}

.checkout-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #857263;
}

.checkout-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  font-size: 24rpx;
  color: #6e5c50;
}

.total-line {
  margin-top: 8rpx;
  padding-top: 18rpx;
  border-top: 1px solid rgba(255, 226, 205, 0.92);
  font-size: 30rpx;
  font-weight: 800;
  color: #ff5a1f;
}

.checkout-submit {
  width: 100%;
  margin-top: 16rpx;
  box-sizing: border-box;
}

.address-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.compact-btn {
  width: 180rpx;
  flex-shrink: 0;
}

.coupon-select-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  margin-top: 16rpx;
  border-radius: 24rpx;
  background: #fff9f4;
  border: 1px solid rgba(255, 219, 191, 0.92);
}

.coupon-select-row-active {
  background: #fff0e2;
  border-color: rgba(255, 154, 72, 0.92);
}

.coupon-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #2c221c;
}

.coupon-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8d7668;
}
