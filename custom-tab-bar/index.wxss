.tab-shell {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  padding: 18rpx 16rpx 24rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 60rpx rgba(34, 57, 93, 0.12);
  backdrop-filter: blur(24rpx);
}

.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 0;
  color: #8f9aac;
}

.tab-item.is-active {
  color: #1957d2;
}

.tab-icon {
  position: relative;
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: #f2f6fc;
  font-size: 26rpx;
  font-weight: 700;
}

.is-active .tab-icon {
  background: linear-gradient(135deg, #1957d2, #46a4ff);
  color: #ffffff;
}

.tab-text {
  font-size: 20rpx;
}

.tab-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff6b57;
  color: #fff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}
