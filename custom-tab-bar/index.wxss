.tab-shell {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  padding: 18rpx 16rpx 24rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1px solid rgba(255, 210, 178, 0.96);
  box-shadow: 0 16rpx 38rpx rgba(165, 83, 18, 0.14);
  backdrop-filter: blur(24rpx);
}

.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 0;
  color: #c6a48f;
}

.tab-item.is-active {
  color: #ff6a00;
}

.tab-icon {
  position: relative;
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #fff5eb;
  border: 1px solid rgba(255, 218, 186, 0.94);
  font-size: 25rpx;
  font-weight: 800;
}

.is-active .tab-icon {
  background: linear-gradient(135deg, #ff6a00, #ff9b2f);
  border-color: transparent;
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(255, 106, 0, 0.22);
}

.tab-text {
  font-size: 20rpx;
  font-weight: 600;
}

.tab-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff3b30;
  color: #fff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}
