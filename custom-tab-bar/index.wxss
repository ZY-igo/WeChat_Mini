.tab-shell {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  padding: 18rpx 16rpx 24rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1px solid rgba(228, 234, 243, 0.96);
  box-shadow: 0 14rpx 40rpx rgba(34, 57, 93, 0.08);
  backdrop-filter: blur(24rpx);
}

.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 0;
  color: #98a4b5;
}

.tab-item.is-active {
  color: #1957d2;
}

.tab-icon {
  position: relative;
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #f4f7fb;
  border: 1px solid rgba(229, 234, 242, 0.94);
  font-size: 25rpx;
  font-weight: 700;
}

.is-active .tab-icon {
  background: linear-gradient(135deg, #1d5fe4, #3f8cff);
  border-color: transparent;
  color: #ffffff;
}

.tab-text {
  font-size: 20rpx;
}

.tab-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff6b57;
  color: #fff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}
